# dev-rules/templates/cloud-agent.env.example — copy to .cursor/cloud-agent.env
# in your project to declare the agent's runtime contract.
#
# Sourced as bash by `dev-rules/templates/cloud-agent-bootstrap.sh`. Every
# variable is OPTIONAL: omit a line to inherit the dev-rules default. The
# defaults assume "claude only, Anthropic SaaS" — the simplest possible setup.
#
# Why this file exists at all:
#   The bootstrap script is generic. The decision of WHAT this project's
#   agent needs (which tools, which secrets, which gateway) belongs to the
#   project, not to dev-rules. Putting it here means the same `bash
#   dev-rules/templates/cloud-agent-bootstrap.sh` works on every project.

# ---------------------------------------------------------------------------
# Tools the agent's runtime depends on (space-separated).
# Auto-installed when missing: claude, gh, jq.
# Listed but not auto-installed (PATH-checked only): anything else, e.g.
# `node`, `pnpm`, `aws`, `docker`. Install those via CLOUD_AGENT_PROJECT_HOOK
# if the cloud agent VM doesn't already have them.
# ---------------------------------------------------------------------------
CLOUD_AGENT_TOOLS="claude"

# ---------------------------------------------------------------------------
# Secrets that MUST be present for the agent to function.
# Cloud: configured in Cursor Dashboard → Cloud Agents → Secrets.
# Local: exported in your shell rc / loaded via direnv / 1Password CLI / etc.
# Bootstrap exits non-zero (and preflight § 9 fails) if any required secret
# is missing.
# ---------------------------------------------------------------------------
CLOUD_AGENT_REQUIRED_SECRETS="ANTHROPIC_API_KEY"

# ---------------------------------------------------------------------------
# Secrets that unlock OPTIONAL capabilities.
# Missing → warning, not failure (the agent still runs without them).
# Example: GH_TOKEN unlocks `gh workflow run` based prod-data fetchers.
# ---------------------------------------------------------------------------
CLOUD_AGENT_OPTIONAL_SECRETS=""

# ---------------------------------------------------------------------------
# Self-hosted Claude Code gateway URL.
# Leave empty (default) to use Anthropic's SaaS API (CLI reads
# ANTHROPIC_API_KEY directly — no settings.json needed).
# Set to e.g. "https://api.tokenkey.dev" if your project routes Claude Code
# through a self-hosted gateway. The bootstrap will then write
# ~/.claude/settings.json with { ANTHROPIC_BASE_URL, ANTHROPIC_AUTH_TOKEN }.
# Pair with CLOUD_AGENT_CLAUDE_TOKEN_VAR if your gateway uses a different
# secret name than ANTHROPIC_AUTH_TOKEN, and add that name to
# CLOUD_AGENT_REQUIRED_SECRETS.
# ---------------------------------------------------------------------------
CLOUD_AGENT_CLAUDE_BASE_URL=""
CLOUD_AGENT_CLAUDE_TOKEN_VAR="ANTHROPIC_AUTH_TOKEN"

# ---------------------------------------------------------------------------
# Project-specific bootstrap hook.
# Runs AFTER the generic install + env check. Receives no args. Use it for:
#   - submodule init / sibling-repo sync
#   - frontend dependency install (pnpm, npm)
#   - heavy or distro-specific tool install (docker, awscli)
#   - project-specific verifications (e.g. `bash scripts/sync-new-api.sh`)
# Must be idempotent. A non-zero exit becomes a warning (install continues)
# so a stale hook does not lock the agent out of every other capability.
# ---------------------------------------------------------------------------
CLOUD_AGENT_PROJECT_HOOK=""
